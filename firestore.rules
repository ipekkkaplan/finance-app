rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Hisse altı yorumlar: stock_comments/{hisseKodu}/comments/{commentId}
    match /stock_comments/{symbol}/comments/{commentId} {
      allow read: if request.auth != null;

      allow create: if request.auth != null
                    && request.resource.data.uid == request.auth.uid
                    && request.resource.data.text is string
                    && request.resource.data.text.size() > 0
                    && request.resource.data.text.size() <= 500;

      allow delete: if request.auth != null
                    && resource.data.uid == request.auth.uid;

      // MVP'de yorum düzenleme yok
      allow update: if false;
    }

    // Diğer mevcut koleksiyonlar (user_match, users/.../risk_profile vb.)
    // şu anki davranışı bozmamak için açık bırakıldı.
    // TODO: Bu kuralları her koleksiyon için kısıtla.
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
